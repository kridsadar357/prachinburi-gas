// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Station {
  id           String   @id
  name         String
  brandId      String   @map("brand_id")
  lat          Float
  lon          Float
  province     String
  district     String?
  latestReport Json?    @map("latest_report")
  syncedAt     DateTime @default(now()) @map("synced_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([province, district])
  @@map("stations")
}

// Stations to hide from the map (wrong location, closed, duplicate, etc.).
model HiddenStation {
  stationId String   @id @map("station_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("hidden_stations")
}

// Tracks out-of-stock status by station and fuel type.
model StationFuelStatus {
  stationId  String    @map("station_id")
  fuelType   String    @map("fuel_type")
  isEmpty    Boolean   @default(false) @map("is_empty")
  lastUpdated DateTime @default(now()) @map("last_updated")

  @@id([stationId, fuelType])
  @@map("station_fuel_status")
}

// Crowdsourced reports with IP-based anti-spam.
model FuelReport {
  id         String   @id @default(cuid())
  stationId  String   @map("station_id")
  fuelType   String   @map("fuel_type")
  userIp     String   @map("user_ip")
  userLat    Float    @map("user_lat")
  userLng    Float    @map("user_lng")
  reportedAt DateTime @default(now()) @map("reported_at")

  @@index([stationId, fuelType, reportedAt])
  @@index([stationId, fuelType, userIp, reportedAt])
  @@map("fuel_reports")
}
